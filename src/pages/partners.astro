---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { productions } from "@/data/site";

const partnerRows = [
  {
    name: "LKAB / Gruvan",
    broadcaster: "Kanal 5 / Discovery+",
    type: "Broadcast & streaming",
    image: "/productions/logolkab.png",
    imageBackground: "#ffffff",
    imageFilter: "none",
    imageOpacity: "0.92",
    imageSize: "68% auto",
    imageTransform: "none",
    overlay: "rgba(5, 5, 5, 0.48)",
    description:
      "Inside one of the world's most advanced and safest mines, a hidden world comes alive. Loved by audiences, the second season shines a light on Sweden's pride once again."
  },
  {
    name: "Boliden / Gruvan",
    broadcaster: "TV3 / Viaplay",
    type: "Broadcast & streaming",
    image: "/productions/bolidenlogo.png",
    imageBackground: "#ffffff",
    imageFilter: "none",
    imageOpacity: "0.9",
    imageSize: "68% auto",
    imageTransform: "none",
    overlay: "rgba(5, 5, 5, 0.5)",
    description:
      "Prime-time reality and factual formats developed for commercial television and streaming."
  },
  {
    name: "Polisen / Stockholm / Norrlandspolisen",
    broadcaster: "TV3 / Viaplay",
    type: "Public service",
    image: "/productions/polisenlogo.png",
    imageBackground: "#ffffff",
    imageFilter: "none",
    imageOpacity: "0.9",
    imageSize: "60% auto",
    imageTransform: "none",
    overlay: "rgba(5, 5, 5, 0.5)",
    description:
      "Documentary, factual and youth-facing productions built around careful editorial handling."
  },
  {
    name: "Tullen / Gränsbevakarna Sverige",
    broadcaster: "Kanal 5 / Discovery+",
    type: "Broadcast & streaming",
    image: "/productions/johanna-moller-card.jpg",
    description:
      "8 seasons of high trust, high impact production resulting in record views and tracktion for Tullen."
  },
  {
    name: "Spotify",
    broadcaster: "Spotify",
    type: "Audio",
    image: "/productions/spotify-dokumentara-poddar-card.jpg",
    description:
      "Documentary podcast series and audio storytelling produced for large-scale digital listening."
  },
  {
    name: "Trafikverket / Vägens Hjältar",
    broadcaster: "Kanal 5 / Discovery",
    type: "Broadcast & streaming",
    image: "/productions/vagens-hjaltar-card.jpg",
    description:
      "Prime-time work-life reality with 18 seasons produced has gained a strong fan base and love for real people."
  },
  {
    name: "Podcast platforms",
    broadcaster: "Podcast platforms",
    type: "Audio distribution",
    image: "/productions/minnet-card.jpg",
    description:
      "Original podcast concepts and recurring formats distributed across open audio platforms."
  },
  {
    name: "Sveriges åkeriföretag  / Truckers",
    broadcaster: "kanal 5 / Dicovery",
    type: "Broadcast & streaming",
    image: "/productions/svenska-truckers-card.jpg",
    description:
      "By shining the light on the right people Sveriges åkeriföretag shows the world those who help make all our daily lives work in this exciting work-life series."
  },
  {
    name: "Region Stockholm / Sjukhuset",
    broadcaster: "kanal 5 / Dicovery",
    type: "Broadcast & streaming",
    image: "/productions/stockholmspolisen-card.jpg",
    description:
      "Region Stockholm invited us to help tell their story through Sjukhuset, resulting in employer branding and a captive audience."
  }
];

const completePartnerRows = partnerRows.filter(
  (partner) => partner.name?.trim() && partner.type?.trim() && partner.description?.trim() && partner.image?.trim()
);

const partnerSummaries = completePartnerRows.map((partner) => {
  const partnerProductions = productions.filter(
    (production) => production.broadcaster === partner.broadcaster
  );

  return {
    ...partner,
    productionCount: partnerProductions.length,
    examples: partnerProductions.slice(0, 3).map((production) => production.title)
  };
});

---

<SiteLayout
  title="Partners and collaborations"
  description="Partners and collaborations across Alaska Film & TV's factual television, documentary, reality, true crime and audio work."
  canonicalPath="/partners"
  prefetchImages={["/mountains/skyline.png"]}
>
  <section class="about-hero partners-hero" aria-labelledby="partners-title">
    <img src="/mountains/skyline.png" alt="Mountain skyline" />
    <div class="about-hero__content">
      <h1 id="partners-title">Collaborations shaped around ambitious factual storytelling.</h1>
    </div>
  </section>

  <section class="partners-intro">
    <div class="about-section-heading">
      <h2>Trusted by private and state actors.</h2>
    </div>
    <p class="partners-lede">
      Our expertise lies in navigating sensitive environments to build the deep trust required for authentic storytelling.
      The collaborations below reflect the platforms represented in the current production archive.
    </p>
  </section>

  <section class="about-stats partners-directory" aria-labelledby="partners-directory-title">
    <header class="about-stats-header">
      <h2 id="partners-directory-title">Selected <em>partners</em></h2>
    </header>

    <div class="partners-list" aria-label="Partner list">
      {
        partnerSummaries.map((partner) => (
          <article
            class="partner-row"
            style={
              [
                `--partner-image: url("${partner.image}")`,
                partner.imageBackground ? `--partner-image-background: ${partner.imageBackground}` : "",
                partner.imageFilter ? `--partner-image-filter: ${partner.imageFilter}` : "",
                partner.imageOpacity ? `--partner-image-opacity: ${partner.imageOpacity}` : "",
                partner.imageSize ? `--partner-image-size: ${partner.imageSize}` : "",
                partner.imageTransform ? `--partner-image-transform: ${partner.imageTransform}` : "",
                partner.overlay ? `--partner-overlay: ${partner.overlay}` : ""
              ]
                .filter(Boolean)
                .join("; ")
            }
          >
            <span class="partner-row__type">{partner.type}</span>
            <div class="partner-row__body">
              <h3>{partner.name}</h3>
              <p>{partner.description}</p>
            </div>
            {
              partner.productionCount > 0 && partner.examples.length > 0 && (
                <div class="partner-row__meta">
                  <span>{partner.productionCount} productions</span>
                  <span>{partner.examples.join(" / ")}</span>
                </div>
              )
            }
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>

---
import ProductionGrid from "@/components/ProductionGrid.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { podcastProductions, showProductions } from "@/data/site";
---

<SiteLayout
  description="Alaska Film & TV is a Stockholm-based production company for factual television, documentary, reality, true crime and audio."
  prefetchImages={["/mountains/skyline.png"]}
>
  <section class="home-stats" aria-label="Alaska Film & TV totals">
    <dl class="home-stats__grid">
      <div>
        <dt>Episodes produced</dt>
        <dd>
          <span class="js-countup" data-countup-target="885" data-countup-suffix=" st">0</span>
        </dd>
      </div>
      <div class="home-stats__item--views">
        <dt>Total views</dt>
        <dd>
          <span class="js-countup" data-countup-target="312710000">0</span>
        </dd>
      </div>
    </dl>
  </section>

  <section class="home-collaboration" aria-labelledby="home-collaboration-title">
    <div class="home-collaboration__grid">
      <dl class="home-collaboration__counter">
        <div>
          <dt>Sammarbetspartners</dt>
          <dd>
            <span class="js-countup" data-countup-target="34" data-countup-suffix=" st">0</span>
          </dd>
        </div>
      </dl>
      <div class="home-collaboration__statement">
        <p
          id="home-collaboration-title"
          class="js-rattle-text"
          data-rattle-text="Statliga och privata bolag, publika aktörer och privatpersoner har tillsammans med Alaska gjort allt vi skapat möjligt!"
        >
          Statliga och privata bolag, publika aktörer och privatpersoner har tillsammans med Alaska gjort allt vi skapat möjligt!
        </p>
      </div>
    </div>
  </section>

  <section class="section-block section-block--archive-grid" aria-labelledby="home-productions-title">
    <h1 id="home-productions-title" class="visually-hidden">Alaska Film & TV productions</h1>
    <ProductionGrid productions={showProductions} labelledBy="home-productions-title" variant="mosaic" />
  </section>

  <section class="section-block podcast-section" aria-labelledby="home-podcast-productions-title">
    <div class="section-heading">
      <h2 id="home-podcast-productions-title">Podcasts</h2>
    </div>
    <ProductionGrid productions={podcastProductions} labelledBy="home-podcast-productions-title" variant="podcast" />
  </section>
</SiteLayout>

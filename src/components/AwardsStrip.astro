---
import { awards } from "@/data/site";
---

<section class="awards-strip" aria-labelledby="awards-heading">
  <div class="section-heading">
    <p class="meta">Awards</p>
    <h2 id="awards-heading">Recognition across Swedish television.</h2>
  </div>
  <div class="awards-strip__grid">
    {
      awards.map((award) => (
        <figure>
          <img src={award.image} alt={award.label} loading="lazy" decoding="async" />
        </figure>
      ))
    }
  </div>
</section>

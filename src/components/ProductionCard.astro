---
import { productionHref, type Production } from "@/data/site";

type Props = {
  production: Production;
  cardRatio?: number;
  cardRows?: number;
};

const { production, cardRatio, cardRows } = Astro.props;
const stats = production.stats?.slice(0, 3) ?? [];
const cardImage = production.cardImage ?? production.image;
const styleVars = [
  cardRatio ? `--card-ratio: ${cardRatio};` : "",
  cardRows ? `--tile-rows: ${cardRows};` : ""
]
  .filter(Boolean)
  .join(" ");
---

<article
  class="production-card"
  data-category={production.category}
  data-slug={production.slug}
  style={styleVars || undefined}
>
  <a
    href={productionHref(production)}
    class="production-card__link"
    aria-label={`View ${production.title}`}
  >
    <div class="production-card__media">
      <img
        src={cardImage}
        alt={`${production.title} production image`}
        loading="eager"
        decoding="sync"
      />
      <div class="production-card__overlay" aria-hidden="true">
        <div class="production-card__overlay-content">
          <dl class="production-card__stats">
            {
              stats.map((stat) => (
                <div>
                  <dt>{stat.label}</dt>
                  <dd>
                    <span
                      class="js-countup"
                      data-countup-target={String(stat.value)}
                      data-countup-suffix={stat.suffix ?? ""}
                    >
                      0
                    </span>
                  </dd>
                </div>
              ))
            }
          </dl>
          <span class="production-card__cta">More info</span>
        </div>
      </div>
    </div>
  </a>
</article>

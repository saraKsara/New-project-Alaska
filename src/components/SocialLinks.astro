---
import { alaskaSite } from "@/data/site";

const socialLinks = [
  {
    href: alaskaSite.socials.instagram,
    label: "Instagram",
    icon: "instagram"
  },
  {
    href: alaskaSite.socials.facebook,
    label: "Facebook",
    icon: "facebook"
  }
];
---

<div class="social-buttons" aria-label="Social media">
  {
    socialLinks.map((link) => (
      <a
        class="social-button"
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${alaskaSite.name} on ${link.label}`}
      >
        {
          link.icon === "instagram" ? (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2" />
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" />
              <circle cx="17.5" cy="6.5" r="1.25" fill="currentColor" />
            </svg>
          ) : (
            <svg class="facebook-icon" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="11" fill="currentColor" />
              <path
                d="M13.4 19v-6.2h2.1l0.4-2.5h-2.5V8.7c0-0.7 0.2-1.2 1.2-1.2h1.4V5.2C15.4 5.1 14.7 5 13.9 5c-2.2 0-3.7 1.4-3.7 3.8v1.5H7.8v2.5h2.4V19h3.2Z"
                fill="#050505"
              />
            </svg>
          )
        }
      </a>
    ))
  }
</div>

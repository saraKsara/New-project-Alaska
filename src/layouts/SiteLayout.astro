---
import SocialLinks from "@/components/SocialLinks.astro";
import { alaskaSite, pageTitle } from "@/data/site";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  bodyClass?: string;
  prefetchImages?: string[];
};

const {
  title,
  description = "A minimalist portfolio for Alaska Film & TV, a Stockholm-based production company.",
  canonicalPath = Astro.url.pathname,
  bodyClass = "",
  prefetchImages = []
} = Astro.props;

const fullTitle = title ? pageTitle(title) : alaskaSite.name;
const canonicalUrl = new URL(canonicalPath, alaskaSite.url).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-default.svg" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      prefetchImages.map((src) => (
        <link rel="prefetch" as="image" href={src} />
      ))
    }
  </head>
  <body class={bodyClass || undefined}>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <a class="brand-lockup" href="/" aria-label="Alaska Film & TV home">
        <img class="brand-logo" src="/alaska-logo-white.png" alt="Alaska Film & TV" />
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/about">About</a>
        <a href="/partners">Partners</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <img class="footer-logo" src="/alaska-logo-white.png" alt="Alaska Film & TV" />
      </div>
      <address>
        <span>{alaskaSite.legalName}</span>
        <span>{alaskaSite.address}</span>
        <a href={`mailto:${alaskaSite.email}`}>{alaskaSite.email}</a>
      </address>
      <SocialLinks />
    </footer>
    <script is:inline>
      (() => {
        const counters = document.querySelectorAll(".js-countup[data-countup-target]");
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        function formatNumber(value) {
          return value.toLocaleString("sv-SE");
        }

        function easeOutExpo(t) {
          return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
        }

        function setCounterValue(el, value) {
          const suffix = el.dataset.countupSuffix || "";
          el.textContent = `${formatNumber(value)}${suffix}`;
        }

        function animateCounter(el) {
          const target = Number.parseInt(el.dataset.countupTarget || "0", 10);
          const duration = target > 500 ? 3200 : target > 100 ? 2600 : 2100;
          const startTime = performance.now();
          const runId = `${startTime}-${target}`;
          el.dataset.countupRunId = runId;

          function tick(now) {
            if (el.dataset.countupRunId !== runId) return;
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const current = Math.round(easeOutExpo(progress) * target);

            setCounterValue(el, current);

            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              setCounterValue(el, target);
            }
          }

          requestAnimationFrame(tick);
        }

        function resetCounter(el) {
          delete el.dataset.countupRunId;
          setCounterValue(el, 0);
        }

        function initCardCounters() {
          document.querySelectorAll(".production-card").forEach((card) => {
            const cardCounters = card.querySelectorAll(".js-countup[data-countup-target]");
            if (!cardCounters.length) return;

            function show() {
              cardCounters.forEach((counter) => {
                const target = Number.parseInt(counter.dataset.countupTarget || "0", 10);
                if (reduceMotion) {
                  setCounterValue(counter, target);
                  return;
                }

                resetCounter(counter);
                animateCounter(counter);
              });
            }

            function hide() {
              if (reduceMotion) return;
              cardCounters.forEach(resetCounter);
            }

            card.addEventListener("mouseenter", show);
            card.addEventListener("mouseleave", hide);
            card.addEventListener("focusin", show);
            card.addEventListener("focusout", hide);
          });
        }

        function initViewportCounters() {
          const standaloneCounters = [...counters].filter(
            (counter) => !counter.closest(".production-card")
          );

          if (!standaloneCounters.length) return;

          if (!("IntersectionObserver" in window) || reduceMotion) {
            standaloneCounters.forEach((counter) => {
              setCounterValue(
                counter,
                Number.parseInt(counter.dataset.countupTarget || "0", 10)
              );
            });
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                animateCounter(entry.target);
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.3 }
          );

          standaloneCounters.forEach((counter) => observer.observe(counter));
        }

        function initRattleText() {
          const rattleTexts = document.querySelectorAll(".js-rattle-text[data-rattle-text]");
          if (!rattleTexts.length) return;

          const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZÅÄÖ0123456789";

          function setFinalText(el) {
            el.textContent = el.dataset.rattleText || "";
          }

          function animateText(el) {
            const finalText = el.dataset.rattleText || "";
            const startTime = performance.now();
            const duration = 1800;
            const runId = `${startTime}-${finalText.length}`;
            el.dataset.rattleRunId = runId;

            function tick(now) {
              if (el.dataset.rattleRunId !== runId) return;

              const progress = Math.min((now - startTime) / duration, 1);
              const resolved = Math.floor(progress * finalText.length);

              el.textContent = finalText
                .split("")
                .map((character, index) => {
                  if (character === " " || index < resolved) return character;
                  return letters[Math.floor(Math.random() * letters.length)];
                })
                .join("");

              if (progress < 1) {
                requestAnimationFrame(tick);
              } else {
                setFinalText(el);
              }
            }

            requestAnimationFrame(tick);
          }

          if (!("IntersectionObserver" in window) || reduceMotion) {
            rattleTexts.forEach(setFinalText);
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                animateText(entry.target);
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.35 }
          );

          rattleTexts.forEach((text) => observer.observe(text));
        }

        function init() {
          initCardCounters();
          initViewportCounters();
          initRattleText();
        }

        document.readyState === "loading"
          ? document.addEventListener("DOMContentLoaded", init)
          : init();
      })();
    </script>
  </body>
</html>

---
import SocialLinks from "@/components/SocialLinks.astro";
import { alaskaSite, pageTitle } from "@/data/site";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  bodyClass?: string;
  prefetchImages?: string[];
};

const {
  title,
  description = "A minimalist portfolio for Alaska Film & TV, a Stockholm-based production company.",
  canonicalPath = Astro.url.pathname,
  bodyClass = "",
  prefetchImages = []
} = Astro.props;

const fullTitle = title ? pageTitle(title) : alaskaSite.name;
const canonicalUrl = new URL(canonicalPath, alaskaSite.url).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-default.svg" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      prefetchImages.map((src) => (
        <link rel="prefetch" as="image" href={src} />
      ))
    }
  </head>
  <body class={bodyClass || undefined}>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <a class="brand-lockup" href="/" aria-label="Alaska Film & TV home">
        <img class="brand-logo" src="/alaska-logo-white.png" alt="Alaska Film & TV" />
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/about">About</a>
        <a href="/partners">Partners</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <img class="footer-logo" src="/alaska-logo-white.png" alt="Alaska Film & TV" />
      </div>
      <address>
        <span>{alaskaSite.legalName}</span>
        <span>{alaskaSite.address}</span>
        <a href={`mailto:${alaskaSite.email}`}>{alaskaSite.email}</a>
      </address>
      <SocialLinks />
    </footer>
    <script is:inline>
      (() => {
        const counters = document.querySelectorAll(".js-countup[data-countup-target]");
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        function formatNumber(value) {
          return value.toLocaleString("sv-SE");
        }

        function easeOutExpo(t) {
          return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
        }

        function setCounterValue(el, value) {
          const suffix = el.dataset.countupSuffix || "";
          el.textContent = `${formatNumber(value)}${suffix}`;
        }

        function reserveCounterSpace(el) {
          const target = Number.parseInt(el.dataset.countupTarget || "0", 10);
          const suffix = el.dataset.countupSuffix || "";
          const finalText = `${formatNumber(target)}${suffix}`;
          el.style.minWidth = `${finalText.length}ch`;
        }

        function animateCounter(el) {
          const target = Number.parseInt(el.dataset.countupTarget || "0", 10);
          const duration = target > 500 ? 3200 : target > 100 ? 2600 : 2100;
          const startTime = performance.now();
          const runId = `${startTime}-${target}`;
          el.dataset.countupRunId = runId;

          function tick(now) {
            if (el.dataset.countupRunId !== runId) return;
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const current = Math.round(easeOutExpo(progress) * target);

            setCounterValue(el, current);

            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              setCounterValue(el, target);
            }
          }

          requestAnimationFrame(tick);
        }

        function resetCounter(el) {
          delete el.dataset.countupRunId;
          setCounterValue(el, 0);
        }

        function initCardCounters() {
          const cards = [...document.querySelectorAll(".production-card")]
            .map((card) => ({
              card,
              counters: [...card.querySelectorAll(".js-countup[data-countup-target]")]
            }))
            .filter(({ counters }) => counters.length > 0);

          if (!cards.length) return;

          function showCard({ card, counters }) {
            card.classList.add("is-mobile-active");

            counters.forEach((counter) => {
                const target = Number.parseInt(counter.dataset.countupTarget || "0", 10);
                if (reduceMotion) {
                  setCounterValue(counter, target);
                  return;
                }

                resetCounter(counter);
                animateCounter(counter);
              });
          }

          function hideCard({ card, counters }) {
            card.classList.remove("is-mobile-active");
            if (reduceMotion) return;
            counters.forEach(resetCounter);
          }

          cards.forEach((cardState) => {
            const { card } = cardState;
            card.addEventListener("mouseenter", show);
            card.addEventListener("mouseleave", hide);
            card.addEventListener("focusin", show);
            card.addEventListener("focusout", hide);

            function show() {
              showCard(cardState);
            }

            function hide() {
              hideCard(cardState);
            }
          });

          const mobileStats = window.matchMedia("(hover: none), (pointer: coarse), (max-width: 699px)").matches;
          if (!mobileStats) return;

          if (!("IntersectionObserver" in window)) {
            cards.forEach(showCard);
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                const cardState = cards.find(({ card }) => card === entry.target);
                if (!cardState) return;

                if (entry.isIntersecting && entry.intersectionRatio >= 0.55) {
                  showCard(cardState);
                } else {
                  hideCard(cardState);
                }
              });
            },
            {
              rootMargin: "-18% 0px -18% 0px",
              threshold: [0, 0.35, 0.55, 0.75]
            }
          );

          cards.forEach(({ card }) => observer.observe(card));
        }

        function initViewportCounters() {
          const standaloneCounters = [...counters].filter(
            (counter) => !counter.closest(".production-card")
          );

          if (!standaloneCounters.length) return;
          standaloneCounters.forEach(reserveCounterSpace);

          if (!("IntersectionObserver" in window) || reduceMotion) {
            standaloneCounters.forEach((counter) => {
              setCounterValue(
                counter,
                Number.parseInt(counter.dataset.countupTarget || "0", 10)
              );
            });
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                animateCounter(entry.target);
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.3 }
          );

          standaloneCounters.forEach((counter) => observer.observe(counter));
        }

        function initRattleText() {
          const rattleTexts = document.querySelectorAll(".js-rattle-text[data-rattle-text]");
          if (!rattleTexts.length) return;

          function setFinalText(el) {
            el.textContent = el.dataset.rattleText || "";
          }

          function revealText(el) {
            setFinalText(el);
            el.classList.remove("is-fade-pending");
            el.classList.add("is-fade-visible");
          }

          if (!("IntersectionObserver" in window) || reduceMotion) {
            rattleTexts.forEach(setFinalText);
            return;
          }

          rattleTexts.forEach((text) => {
            setFinalText(text);
            text.classList.add("is-fade-pending");
          });

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                revealText(entry.target);
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.35 }
          );

          rattleTexts.forEach((text) => observer.observe(text));
        }

        function initDragCarousels() {
          const carousels = document.querySelectorAll(".js-drag-carousel");
          if (!carousels.length) return;

          carousels.forEach((carousel) => {
            if (carousel.dataset.carouselReady === "true") return;
            carousel.dataset.carouselReady = "true";

            const gallery = carousel.closest(".detail-gallery");
            const dots = [...(gallery?.querySelectorAll(".js-carousel-dot") ?? [])];
            const originalSlides = [...carousel.querySelectorAll(".detail-gallery__slide")];
            let isDragging = false;
            let startX = 0;
            let startScrollLeft = 0;

            function slideScrollLeft(slide) {
              const paddingLeft = Number.parseFloat(getComputedStyle(carousel).paddingLeft) || 0;
              return slide.offsetLeft - paddingLeft;
            }

            function scrollToSlide(slide, behavior = "smooth") {
              carousel.scrollTo({
                left: slideScrollLeft(slide),
                behavior
              });
            }

            function getClosestSlide() {
              const viewportCenter = carousel.scrollLeft + carousel.clientWidth / 2;

              return originalSlides.reduce((closest, slide) => {
                const slideCenter = slide.offsetLeft + slide.offsetWidth / 2;
                const distance = Math.abs(slideCenter - viewportCenter);

                if (!closest || distance < closest.distance) {
                  return { slide, distance };
                }

                return closest;
              }, null)?.slide;
            }

            function updateDots(index) {
              dots.forEach((dot) => {
                const isActive = Number.parseInt(dot.dataset.carouselDot || "0", 10) === index;
                dot.classList.toggle("is-active", isActive);

                if (isActive) {
                  dot.setAttribute("aria-current", "true");
                } else {
                  dot.removeAttribute("aria-current");
                }
              });
            }

            function activeIndexFromClosestSlide() {
              const closestSlide = getClosestSlide();
              const index = Number.parseInt(closestSlide?.dataset.carouselIndex || "0", 10);
              return Number.isFinite(index) ? index : 0;
            }

            updateDots(0);

            carousel.addEventListener("pointerdown", (event) => {
              if (event.pointerType === "mouse" && event.button !== 0) return;

              isDragging = true;
              startX = event.clientX;
              startScrollLeft = carousel.scrollLeft;
              carousel.classList.add("is-dragging");
              carousel.setPointerCapture?.(event.pointerId);
            });

            carousel.addEventListener("pointermove", (event) => {
              if (!isDragging) return;

              const deltaX = event.clientX - startX;
              carousel.scrollLeft = startScrollLeft - deltaX;
            });

            function stopDragging(event) {
              if (!isDragging) return;

              isDragging = false;
              carousel.classList.remove("is-dragging");
              carousel.releasePointerCapture?.(event.pointerId);
            }

            carousel.addEventListener("pointerup", stopDragging);
            carousel.addEventListener("pointercancel", stopDragging);
            carousel.addEventListener("dragstart", (event) => event.preventDefault());

            carousel.addEventListener(
              "scroll",
              () => {
                updateDots(activeIndexFromClosestSlide());
              },
              { passive: true }
            );

            dots.forEach((dot) => {
              dot.addEventListener("click", () => {
                const index = Number.parseInt(dot.dataset.carouselDot || "0", 10);
                const slide = originalSlides[index];
                if (!slide) return;

                scrollToSlide(slide);
                updateDots(index);
              });
            });
          });
        }

        function init() {
          initCardCounters();
          initViewportCounters();
          initRattleText();
          initDragCarousels();
        }

        document.readyState === "loading"
          ? document.addEventListener("DOMContentLoaded", init)
          : init();
      })();
    </script>
  </body>
</html>
